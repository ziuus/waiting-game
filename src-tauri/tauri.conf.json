{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "waiting-game",
  "version": "0.3.5",
  "identifier": "com.zius.waiting-game",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "waiting-game",
        "width": 1920,
        "height": 1080,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "backgroundColor": [0, 0, 0, 0],
        "alwaysOnTop": false,
        "resizable": false,
        "skipTaskbar": true,
        "visible": true
      },
      {
        "label": "settings",
        "title": "Settings Hub",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true
      }
    ],    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [],
        "desktopTemplate": "main.desktop"
      }
    },
    "shortDescription": "Cinematic kinetic overlay game for developers.",
    "longDescription": "An ultra-lightweight, full-screen transparent overlay game designed for high-performance focus during idle times.",
    "copyright": "Copyright © 2026 Noel Paul Tomy",
    "category": "Game"
  }
}
