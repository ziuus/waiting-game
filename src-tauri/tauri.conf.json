{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "waiting-game",
  "version": "0.1.0",
  "identifier": "com.zius.waiting-game",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
    {
    "label": "main",
    "title": "waiting-game",
    "width": 1920,
    "height": 1080,
    "fullscreen": false,
    "decorations": false,
    "transparent": true,
    "alwaysOnTop": false,
    "resizable": false,
    "skipTaskbar": true,
    "visible": true
    }
    ],    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
