{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "waiting-game",
  "version": "0.2.8",
  "identifier": "com.zius.waiting-game",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "waiting-game",
        "width": 1920,
        "height": 1080,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "resizable": false,
        "skipTaskbar": true,
        "visible": true
      },
      {
        "label": "settings",
        "title": "Settings Hub",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "center": true,
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true
      }
    ],    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
